{
  "name": "inertia",
  "private": true,
  "version": "1.0.0-alpha",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=DEP0040 vite dev --host",
    "build": "NODE_OPTIONS=--disable-warning=DEP0040 tsgo -b && NODE_OPTIONS=--disable-warning=DEP0040 vite build",
    "lint": "oxlint -c oxlintrc.json --type-check --type-aware .",
    "lint:knip": "NODE_OPTIONS=--disable-warning=DEP0040 knip --config knip.json",
    "test": "NODE_OPTIONS=--disable-warning=DEP0040 vitest run",
    "coverage": "NODE_OPTIONS=--disable-warning=DEP0040 vitest run --coverage",
    "test:e2e": "playwright test",
    "seed": "open http://localhost:5173/?seed=true",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1 && pnpm wrangler d1 migrations apply kinetic-cloud --local",
    "db:reset:prod": "echo 'WARNING: THIS WILL DELETE ALL PRODUCTION DATA' && pnpm wrangler d1 execute kinetic-cloud --remote --command \"DROP TABLE IF EXISTS sync_store; DROP TABLE IF EXISTS sync_events; DROP TABLE IF EXISTS refresh_sessions; DROP TABLE IF EXISTS audit_log; DROP TABLE IF EXISTS d1_migrations;\" && pnpm wrangler d1 migrations apply kinetic-cloud --remote",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@ericblade/quagga2": "^1.12.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@react-oauth/google": "^0.13.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.161.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dexie-export-import": "^4.1.4",
    "hono": "^4.12.25",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.2",
    "@cloudflare/workers-types": "^4.20260228.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/router-devtools": "^1.161.4",
    "@tanstack/router-plugin": "^1.161.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260220.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "msw": "^2.12.10",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.14.2",
    "rolldown": "1.0.0-rc.5",
    "rolldown-vite": "^7.3.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.0",
    "vite": "7.3.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.67.0"
  }
}
