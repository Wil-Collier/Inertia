    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed": "open http://localhost:5173/?seed=true",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy"
  },
