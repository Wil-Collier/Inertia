  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite dev --host",
    "build": "tsgo -b && vite build",
    "lint": "oxlint -c oxlintrc.json --type-check --type-aware .",
