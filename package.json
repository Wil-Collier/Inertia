{
  "name": "inertia",
  "private": true,
  "version": "1.0.0-alpha",
  "packageManager": "pnpm@11.13.1",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=DEP0040 vite dev --host",
    "build": "NODE_OPTIONS=--disable-warning=DEP0040 tsgo -b && NODE_OPTIONS=--disable-warning=DEP0040 vite build",
    "lint": "oxlint -c oxlintrc.json --type-check --type-aware .",
    "lint:knip": "NODE_OPTIONS=--disable-warning=DEP0040 knip --config knip.json",
    "test": "NODE_OPTIONS=--disable-warning=DEP0040 vitest run",
    "coverage": "NODE_OPTIONS=--disable-warning=DEP0040 vitest run --coverage",
    "test:e2e": "playwright test",
    "seed": "open http://localhost:5173/?seed=true",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1 && pnpm wrangler d1 migrations apply kinetic-cloud --local",
    "db:reset:prod": "echo 'WARNING: THIS WILL DELETE ALL PRODUCTION DATA' && pnpm wrangler d1 execute kinetic-cloud --remote --command \"DROP TABLE IF EXISTS sync_store; DROP TABLE IF EXISTS sync_events; DROP TABLE IF EXISTS refresh_sessions; DROP TABLE IF EXISTS audit_log; DROP TABLE IF EXISTS d1_migrations;\" && pnpm wrangler d1 migrations apply kinetic-cloud --remote",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@ericblade/quagga2": "^1.12.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.4",
    "dexie-export-import": "^4.4.0",
    "hono": "^4.12.30",
    "lucide-react": "^0.575.0",
    "react": "^19.2.7",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@cloudflare/workers-types": "5.20260714.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.21",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "29.1.1",
    "knip": "^5.85.0",
    "msw": "^2.15.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "7.0.2001",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.3.3",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "wrangler": "4.112.0"
  }
}
